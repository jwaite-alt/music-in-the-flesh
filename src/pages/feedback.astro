---
import PageLayout from '../layouts/PageLayout.astro';

const FORM_ENDPOINT = 'https://script.google.com/macros/s/AKfycbzTBsOf1AwhujooMvcGNqPXPcyxS7ZxG9Ek7ptoMomJaK-v0k7dfDhn7L-jiuzui4Ghog/exec';
---

<PageLayout
  title="Contact"
  heading="Contact"
  description="Get in touch with the Music in the Flesh project."
>

  <div class="contact-wrap">
    <form class="contact-form" id="contact-form" novalidate>

      <!-- Honeypot — hidden from humans, filled by bots -->
      <input type="text" name="website" autocomplete="off" tabindex="-1" aria-hidden="true" class="hp" />

      <div class="field">
        <label for="name">Name <span class="required">*</span></label>
        <input type="text" id="name" name="name" autocomplete="name" required />
      </div>

      <div class="field">
        <label for="email">Email <span class="required">*</span></label>
        <input type="email" id="email" name="email" autocomplete="email" required />
      </div>

      <div class="field">
        <label for="message">Message <span class="required">*</span></label>
        <textarea id="message" name="message" rows="7" required></textarea>
      </div>

      <div class="field field--check">
        <label class="check-label">
          <input type="checkbox" id="updates" name="updates" />
          <span>Tick here to receive updates about <em>Music in the Flesh</em> events</span>
        </label>
      </div>

      <button type="submit" class="btn btn--crimson" id="contact-submit">Send message</button>

      <p class="form-status" id="form-status" aria-live="polite"></p>
    </form>
  </div>

</PageLayout>

<script define:vars={{ FORM_ENDPOINT }}>
  const form   = document.getElementById('contact-form');
  const btn    = document.getElementById('contact-submit');
  const status = document.getElementById('form-status');

  form.addEventListener('submit', async (e) => {
    e.preventDefault();

    const name    = form.name.value.trim();
    const email   = form.email.value.trim();
    const message = form.message.value.trim();
    const website = form.website.value;
    const updates = form.updates.checked;

    if (!name || !email || !message) {
      status.textContent = 'Please fill in all required fields.';
      status.className = 'form-status form-status--error';
      return;
    }

    btn.disabled = true;
    btn.textContent = 'Sending…';
    status.textContent = '';
    status.className = 'form-status';

    try {
      const res = await fetch(FORM_ENDPOINT, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ type: 'contact', name, email, message, website, updates }),
      });

      const json = await res.json();

      if (json.status === 'ok') {
        form.reset();
        status.textContent = 'Thank you — your message has been sent.';
        status.className = 'form-status form-status--ok';
        btn.textContent = 'Sent';
      } else {
        throw new Error(json.message || 'Unknown error');
      }
    } catch (err) {
      status.textContent = 'Something went wrong. Please try again or email us directly.';
      status.className = 'form-status form-status--error';
      btn.disabled = false;
      btn.textContent = 'Send message';
    }
  });
</script>

<style>
  .contact-wrap {
    max-width: 52ch;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  /* Honeypot — visually hidden but not display:none (some bots detect that) */
  .hp {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    opacity: 0;
    tab-index: -1;
  }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.4em;
  }

  label {
    font-family: var(--font-display);
    font-size: var(--size-sm);
    font-weight: 600;
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-ink-light);
  }

  .required {
    color: var(--color-crimson);
  }

  input[type="text"],
  input[type="email"],
  textarea {
    font-family: var(--font-body);
    font-size: var(--size-base);
    color: var(--color-ink);
    background: var(--color-cream);
    border: 1px solid var(--color-kraft);
    padding: 0.6em 0.8em;
    width: 100%;
    transition: border-color var(--transition);
    resize: vertical;
  }

  input[type="text"]:focus,
  input[type="email"]:focus,
  textarea:focus {
    outline: none;
    border-color: var(--color-crimson);
  }

  .field--check {
    flex-direction: row;
    align-items: flex-start;
  }

  .check-label {
    display: flex;
    align-items: flex-end;
    gap: 0.6em;
    font-family: var(--font-body);
    font-size: var(--size-base);
    font-weight: 400;
    letter-spacing: normal;
    text-transform: none;
    color: var(--color-ink);
    cursor: pointer;
  }

  .check-label input[type="checkbox"] {
    margin-top: 0;
    flex-shrink: 0;
    accent-color: var(--color-crimson);
    width: 1.1em;
    height: 1.1em;
  }

  .form-status {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--size-base);
    min-height: 1.5em;
  }

  .form-status--ok    { color: #3a5a3a; }
  .form-status--error { color: var(--color-crimson); }
</style>
