---
import BaseLayout from '../layouts/BaseLayout.astro';
import EventCard from '../components/EventCard.astro';
import { getCollection, getEntry, render } from 'astro:content';

const base = import.meta.env.BASE_URL;
const homePage = await getEntry('pages', 'home');
const { Content: HomeContent } = await render(homePage);
const performances = await getCollection('performances', ({ data }) => !data.draft);
const recentArchive = performances
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .slice(0, 2);

// Featured media items for homepage preview
const allVideos = await getCollection('videos', ({ data }) => !data.draft && data.featured);
const allGalleries = await getCollection('galleries', ({ data }) => !data.draft && data.featured);

// Interleave featured videos and galleries, up to 2 items total
const featuredMedia = [
  ...allVideos.map(v => ({ type: 'video' as const, item: v })),
  ...allGalleries.map(g => ({ type: 'gallery' as const, item: g })),
].sort((a, b) => new Date(b.item.data.date).getTime() - new Date(a.item.data.date).getTime())
 .slice(0, 2);

function youtubeThumbnail(embedUrl: string) {
  const match = embedUrl.match(/youtube\.com\/embed\/([^?]+)/);
  return match ? `https://img.youtube.com/vi/${match[1]}/hqdefault.jpg` : '';
}

function titleHtml(title: string) {
  return title.replace(/[*_](.*?)[*_]/g, '<em>$1</em>');
}
---

<BaseLayout title="Music in the Flesh">

  <!-- Hero -->
  <section class="hero section--parchment">
    <div class="container hero__inner">
      <div class="hero__text">
        <p class="label hero__kicker">Bettina Varwig · University of Cambridge</p>
        <h1 class="hero__title">
          <span class="hero__title-music">Music</span>
          <span class="hero__title-in">in the</span>
          <span class="hero__title-flesh">Flesh</span>
        </h1>
        <p class="hero__subtitle display-subtitle">An Early Modern Musical Physiology</p>
        <p class="hero__intro">{homePage.data.hero_intro}</p>
        <div class="hero__actions">
          <a href={`${base}about-project`} class="btn btn--crimson">About the Project</a>
          <a href={`${base}media`} class="btn btn--ink">Media</a>
        </div>
      </div>
      <div class="hero__book">
        <a href="https://press.uchicago.edu/ucp/books/book/chicago/M/bo196672081.html" target="_blank" rel="noopener" class="hero__book-link">
          <img
            src={`${base}images/book-cover.jpg`}
            alt="Music in the Flesh — An Early Modern Musical Physiology, by Bettina Varwig"
            class="hero__cover"
          />
        </a>
      </div>
    </div>
  </section>

  <!-- Book description -->
  <section class="section">
    <div class="container container--prose">
      <p class="label" style="color: var(--color-crimson); margin-bottom: 1em;">A corporeal history of music-making in early modern Europe</p>
      <div class="prose"><HomeContent /></div>
      <a href={`${base}about`} class="btn btn--crimson" style="margin-top: var(--space-md);">Biographies</a>
    </div>
  </section>

  <!-- Media preview -->
  {featuredMedia.length > 0 && (
    <section class="section section--parchment">
      <div class="container">
        <p class="label" style="color: var(--color-crimson); margin-bottom: var(--space-sm);">Media</p>
        <hr class="rule rule--crimson" />
        <div class="media-preview">
          {featuredMedia.map(({ type, item }) => {
            const href = type === 'video'
              ? `${base}media/videos/${item.id}`
              : `${base}media/photos/${item.id}`;
            const thumb = type === 'video'
              ? (item.data.thumbnail || youtubeThumbnail((item.data as any).embedUrl))
              : (item.data as any).images?.[0]?.image;
            return (
              <a href={href} class="media-preview__card">
                <div class="media-preview__thumb">
                  {thumb && <img src={thumb} alt={item.data.title} />}
                  {type === 'video' && <span class="media-preview__play">▶</span>}
                </div>
                <p class="label media-preview__type" style="color: var(--color-crimson); margin-top: var(--space-xs);">
                  {type === 'video' ? 'Video' : 'Photography'}
                </p>
                <p class="media-preview__title" set:html={titleHtml(item.data.title)} />
              </a>
            );
          })}
        </div>
        <a href={`${base}media`} class="btn btn--ink" style="margin-top: var(--space-md);">All media</a>
      </div>
    </section>
  )}

  <!-- Archive preview -->
  {recentArchive.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-heading">From the Archive</h2>
        <hr class="rule rule--crimson" />
        {recentArchive.map(p => (
          <EventCard
            title={p.data.title}
            date={p.data.date}
            venue={p.data.venue}
            description={p.data.description}
            slug={p.id}
          />
        ))}
        <a href={`${base}archive`} class="btn btn--ink" style="margin-top: var(--space-sm);">View full archive</a>
      </div>
    </section>
  )}

</BaseLayout>

<style>
  .hero {
    border-bottom: 1px solid var(--color-kraft);
  }

  .hero__inner {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: var(--space-xl);
    padding-block: var(--space-2xl);
  }

  .hero__kicker {
    margin-bottom: var(--space-sm);
  }

  .hero__title {
    display: flex;
    flex-direction: column;
    line-height: 1;
    margin-bottom: 0.5em;
  }

  .hero__title-music {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--size-4xl);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-crimson);
  }

  .hero__title-in {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 400;
    font-size: var(--size-2xl);
    color: var(--color-slate);
    margin-left: 0.1em;
    margin-block: 0.1em;
  }

  .hero__title-flesh {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--size-4xl);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-crimson);
  }

  .hero__subtitle {
    font-size: var(--size-lg);
    margin-bottom: var(--space-md);
  }

  .hero__intro {
    max-width: 54ch;
    margin-bottom: var(--space-md);
    color: var(--color-ink-light);
  }

  .hero__actions {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .hero__book {
    flex-shrink: 0;
    align-self: center;
  }

  .hero__book-link {
    display: block;
  }

  .hero__cover {
    width: 340px;
    height: auto;
    box-shadow: 8px 12px 32px rgba(28, 21, 13, 0.25);
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .hero__book-link:hover .hero__cover {
    box-shadow: 12px 18px 40px rgba(28, 21, 13, 0.4);
    transform: translateY(-3px);
    opacity: 1;
  }

  .section-heading {
    color: var(--color-crimson);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-size: var(--size-xl);
    margin-bottom: 0.25em;
  }

  /* Media preview */
  .media-preview {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-md);
    margin-top: var(--space-md);
  }

  .media-preview__card {
    display: block;
    color: var(--color-ink);
    text-decoration: none;
    transition: opacity var(--transition);
  }

  .media-preview__card:hover {
    opacity: 0.85;
  }

  .media-preview__thumb {
    position: relative;
    width: 100%;
    aspect-ratio: 16/9;
    background-color: var(--color-kraft);
    overflow: hidden;
  }

  .media-preview__thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .media-preview__play {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
    color: var(--color-cream);
    text-shadow: 0 2px 8px rgba(0,0,0,0.5);
  }

  .media-preview__title {
    font-family: var(--font-display);
    font-size: var(--size-md);
    font-weight: 600;
    margin-top: 0.25em;
  }

  @media (max-width: 768px) {
    .hero__inner {
      grid-template-columns: 1fr;
      padding-block: var(--space-xl);
    }

    .hero__book {
      display: none;
    }

    .hero__title-music,
    .hero__title-flesh {
      font-size: var(--size-3xl);
    }
  }
</style>
