---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const videos = await getCollection('videos', ({ data }) => !data.draft);
  return videos.map(v => ({ params: { slug: v.id }, props: { video: v } }));
}

const { video } = Astro.props;
const { Content } = await render(video);
const base = import.meta.env.BASE_URL;

const dateObj = new Date(video.data.date);
const formattedDate = dateObj.toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric',
});

const titleHtml = video.data.title.replace(/[*_](.*?)[*_]/g, '<em>$1</em>');
---

<BaseLayout title={`${video.data.title} — Media`}>

  <header class="page-header section--parchment">
    <div class="container">
      <p class="label" style="color: var(--color-crimson); margin-bottom: 0.5em;">Video</p>
      <h1 class="page-header__title" set:html={titleHtml} />
      <p class="page-header__sub display-subtitle">{formattedDate}</p>
    </div>
  </header>

  <div class="container video-body">

    <div class="video-embed">
      <iframe
        src={video.data.embedUrl}
        title={video.data.title}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>

    {video.data.description && (
      <p class="video-desc">{video.data.description}</p>
    )}

    <div class="prose">
      <Content />
    </div>

    <div class="video-nav">
      <a href={`${base}media#videos`} class="btn btn--ink">&larr; All videos</a>
    </div>

  </div>

</BaseLayout>

<style>
  .page-header {
    border-bottom: 1px solid var(--color-kraft);
    padding-block: var(--space-lg);
  }

  .page-header__title {
    color: var(--color-crimson);
    font-size: var(--size-3xl);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
  }

  .page-header__sub {
    margin-top: 0.4em;
    font-size: var(--size-md);
    color: var(--color-slate);
  }

  .video-body {
    padding-block: var(--space-xl);
  }

  .video-embed {
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    background-color: var(--color-ink);
    margin-bottom: var(--space-lg);
  }

  .video-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .video-desc {
    color: var(--color-ink-light);
    font-size: var(--size-base);
    max-width: var(--max-prose);
    margin-bottom: var(--space-lg);
  }

  .video-nav {
    margin-top: var(--space-xl);
  }
</style>
