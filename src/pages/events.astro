---
import PageLayout from '../layouts/PageLayout.astro';
import { getCollection } from 'astro:content';

const events = await getCollection('events', ({ data }) => !data.draft);
const upcoming = events
  .filter(e => new Date(e.data.date) >= new Date())
  .sort((a, b) => new Date(a.data.date).getTime() - new Date(b.data.date).getTime());

const past = events
  .filter(e => new Date(e.data.date) < new Date())
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<PageLayout
  title="Upcoming Events"
  heading="Upcoming Events"
  subheading="Performances, talks, and experiments"
  description="Forthcoming Music in the Flesh events — performances, talks, and research experiments."
>

  {upcoming.length === 0 ? (
    <p style="color: var(--color-ink-light); font-style: italic; margin-bottom: var(--space-lg);">
      No events are currently scheduled. Please check back soon, or register your interest below.
    </p>
  ) : (
    <div style="margin-bottom: var(--space-xl);">
      {upcoming.map(e => {
        const dateObj = new Date(e.data.date);
        const formattedDate = dateObj.toLocaleDateString('en-GB', {
          day: 'numeric', month: 'long', year: 'numeric'
        });
        return (
          <article class="event-listing">
            <p class="label event-listing__date">{formattedDate}</p>
            <h3 class="event-listing__title">{e.data.title}</h3>
            <p class="event-listing__venue">{e.data.venue}{e.data.location ? `, ${e.data.location}` : ''}</p>
            <p class="event-listing__desc">{e.data.description}</p>
            {e.data.ticketUrl && (
              <a href={e.data.ticketUrl} class="btn btn--crimson" target="_blank" rel="noopener">
                Tickets / more information
              </a>
            )}
          </article>
        );
      })}
    </div>
  )}

  <!-- Expression of interest form -->
  <section class="interest-form section--parchment" style="padding: var(--space-lg);">
    <h2 class="interest-form__heading">Register your interest</h2>
    <p style="margin-bottom: var(--space-md); max-width: 54ch; color: var(--color-ink-light);">
      To be notified of future performances and events, please leave your name and email address.
      We'll be in touch when new events are confirmed.
    </p>
    <form class="interest-form__form" id="interest-form" novalidate>
      <!-- Honeypot: hidden from real users, bots fill it in -->
      <div class="hp-field" aria-hidden="true">
        <label for="website">Website</label>
        <input type="text" id="website" name="website" tabindex="-1" autocomplete="off" />
      </div>
      <div class="form-field">
        <label for="name" class="label">Name</label>
        <input type="text" id="name" name="name" autocomplete="name" required />
      </div>
      <div class="form-field">
        <label for="email" class="label">Email</label>
        <input type="email" id="email" name="email" autocomplete="email" required />
      </div>
      <button type="submit" class="btn btn--crimson" id="interest-submit">Register interest</button>
      <p class="form-status" id="form-status" role="status" aria-live="polite"></p>
    </form>
  </section>

  <script>
    const FORM_ENDPOINT = 'PASTE_YOUR_APPS_SCRIPT_URL_HERE';

    const form   = document.getElementById('interest-form');
    const btn    = document.getElementById('interest-submit');
    const status = document.getElementById('form-status');

    form.addEventListener('submit', async (e) => {
      e.preventDefault();

      const name    = form.name.value.trim();
      const email   = form.email.value.trim();
      const website = form.website.value; // honeypot

      if (!name || !email) {
        showStatus('Please fill in both fields.', 'error');
        return;
      }

      btn.disabled = true;
      btn.textContent = 'Sending…';
      showStatus('', '');

      try {
        // mode: 'no-cors' is required for Google Apps Script endpoints —
        // they use a redirect that blocks cross-origin response reading.
        // The data still reaches the sheet; we just can't read the response.
        await fetch(FORM_ENDPOINT, {
          method: 'POST',
          mode: 'no-cors',
          body: JSON.stringify({ name, email, website }),
        });

        form.reset();
        btn.textContent = 'Sent';
        showStatus("Thank you \u2014 we\u2019ll be in touch when new events are confirmed.", 'success');
      } catch (err) {
        btn.disabled = false;
        btn.textContent = 'Register interest';
        showStatus('Something went wrong. Please try again or email us directly.', 'error');
      }
    });

    function showStatus(msg, type) {
      status.textContent = msg;
      status.className = 'form-status' + (type ? ' form-status--' + type : '');
    }
  </script>

</PageLayout>

<style>
  .event-listing {
    border-top: 1px solid var(--color-kraft);
    padding-block: var(--space-md);
  }

  .event-listing__date {
    color: var(--color-ink-light);
    margin-bottom: 0.25em;
  }

  .event-listing__title {
    font-size: var(--size-xl);
    color: var(--color-ink);
    margin-bottom: 0.25em;
  }

  .event-listing__venue {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-slate);
    margin-bottom: var(--space-sm);
  }

  .event-listing__desc {
    color: var(--color-ink-light);
    max-width: 60ch;
    margin-bottom: var(--space-sm);
  }

  .interest-form__heading {
    color: var(--color-crimson);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    font-size: var(--size-xl);
    margin-bottom: 0.5em;
  }

  .interest-form__form {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    max-width: 440px;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.4em;
  }

  .form-field input {
    font-family: var(--font-body);
    font-size: var(--size-base);
    padding: 0.6em 0.8em;
    border: 1px solid var(--color-kraft);
    background-color: var(--color-cream);
    color: var(--color-ink);
    outline: none;
    transition: border-color var(--transition);
  }

  .form-field input:focus {
    border-color: var(--color-crimson);
  }

  /* Honeypot — visually hidden but not display:none (some bots skip those) */
  .hp-field {
    position: absolute;
    left: -9999px;
    width: 1px;
    height: 1px;
    overflow: hidden;
  }

  .form-status {
    font-size: var(--size-sm);
    min-height: 1.4em;
  }

  .form-status--success { color: var(--color-slate); }
  .form-status--error   { color: var(--color-crimson); }
</style>
