---
const year = new Date().getFullYear();
const base = import.meta.env.BASE_URL;
---

<footer class="footer">
  <div class="container footer__inner">
    <div class="footer__brand">
      <p class="footer__title">Music in the Flesh</p>
    </div>

    <nav class="footer__nav" aria-label="Footer navigation">
      <ul role="list">
        <li><a href={base}>Home</a></li>
        <li><a href={`${base}about`}>Biographies</a></li>
        <li><a href={`${base}media`}>Media</a></li>
        <li><a href={`${base}archive`}>Archive</a></li>
        <li><a href={`${base}events`}>Upcoming Events</a></li>
        <li><a href={`${base}feedback`}>Contact</a></li>
      </ul>
    </nav>

    <div class="footer__institution">
      <p>Faculty of Music</p>
      <p>University of Cambridge</p>
    </div>
  </div>

  <div class="footer__base">
    <div class="container container--wide">
      <p>&copy; {year} Bettina Varwig. All rights reserved.</p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background-color: var(--color-ink);
    color: var(--color-parchment);
    margin-top: auto;
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr;
    gap: var(--space-lg);
    padding-block: var(--space-xl);
  }

  .footer__title {
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--size-lg);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-parchment);
  }

  .footer__subtitle {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--size-base);
    color: var(--color-kraft);
    margin-top: 0.25em;
  }

  .footer__author {
    font-family: var(--font-display);
    font-size: var(--size-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-kraft);
    margin-top: 1em;
  }

  .footer__nav ul {
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.5em;
  }

  .footer__nav a {
    font-family: var(--font-display);
    font-size: var(--size-sm);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-kraft);
    transition: color var(--transition);
  }

  .footer__nav a:hover {
    color: var(--color-parchment);
    opacity: 1;
  }

  .footer__institution {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--size-sm);
    color: var(--color-kraft);
    line-height: 1.6;
  }

  .footer__base {
    border-top: 1px solid #3a2e20;
    padding-block: var(--space-sm);
  }

  .footer__base p {
    font-size: var(--size-xs);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-ink-light);
    color: #6b5a42;
  }

  @media (max-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }
  }
</style>
