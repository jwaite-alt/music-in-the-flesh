---
import PageLayout from '../../layouts/PageLayout.astro';
import EventCard from '../../components/EventCard.astro';
import { getCollection } from 'astro:content';

const performances = await getCollection('performances', ({ data }) => !data.draft);
const sorted = performances.sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---

<PageLayout
  title="Archive"
  heading="Archive"
  subheading="Past performances, events and experiments"
  description="A record of all past Music in the Flesh performances and research events."
>

  <p style="margin-bottom: var(--space-lg); color: var(--color-ink-light);">
    The archive documents each performance experiment arising from the research behind
    <em>Music in the Flesh</em> — including programme notes, contextual essays, images, and
    where available, video documentation and audience feedback.
  </p>

  {sorted.map(p => (
    <EventCard
      title={p.data.title}
      date={p.data.date}
      venue={p.data.venue}
      description={p.data.description}
      slug={p.id}
      tag={p.data.featured ? 'Featured' : undefined}
    />
  ))}

</PageLayout>
