---
import PageLayout from '../layouts/PageLayout.astro';
import { getEntry, render } from 'astro:content';
const base = import.meta.env.BASE_URL;
const aboutPage = await getEntry('pages', 'about');
const { Content: AboutContent } = await render(aboutPage);
---

<PageLayout
  title="About Bettina"
  heading="Bettina Varwig"
  subheading="Professor of Music History · University of Cambridge"
  description="Bettina Varwig — professor of music history and fellow of Emmanuel College, University of Cambridge."
  narrow={false}
>

  <div class="about-body">

    <img
      src={`${base}images/bettina.jpg`}
      alt="Bettina Varwig"
      class="about-photo"
    />

    <div class="prose">
      <AboutContent />
      <div style="margin-top: var(--space-lg);">
        <a href={`${base}about-project`} class="btn btn--crimson">About the Project</a>
      </div>
    </div>
  </div>

</PageLayout>

<style>
  .about-body {
    display: grid;
    grid-template-columns: 220px minmax(0, 60ch);
    gap: var(--space-xl);
    align-items: start;
  }

  .about-photo {
    width: 100%;
    height: auto;
    filter: grayscale(20%) sepia(10%);
    border: 1px solid var(--color-kraft);
    margin-top: 1em;
  }

  @media (max-width: 768px) {
    .about-body {
      grid-template-columns: 1fr;
    }

    .about-photo {
      max-width: 200px;
    }
  }
</style>
