<?php
/**
 * OAuth credentials for the GitHub OAuth handler.
 *
 * SETUP
 * -----
 * 1. Copy this file to credentials.php in the same directory
 * 2. Fill in your GitHub OAuth App values
 * 3. Make sure credentials.php is NOT committed to git (it is in .gitignore)
 *
 * Alternatively, set these as server environment variables:
 *   OAUTH_CLIENT_ID
 *   OAUTH_CLIENT_SECRET
 *   OAUTH_REDIRECT_URI
 *
 * WHERE TO FIND THESE VALUES
 * --------------------------
 * GitHub → Settings → Developer settings → OAuth Apps → [your app]
 * The redirect URI must exactly match the callback URL registered there.
 */

$clientId     = 'YOUR_GITHUB_OAUTH_APP_CLIENT_ID';
$clientSecret = 'YOUR_GITHUB_OAUTH_APP_CLIENT_SECRET';
$redirectUri  = 'https://yourdomain.com/path/to/oauth/callback';
