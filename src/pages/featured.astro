---
import PageLayout from '../layouts/PageLayout.astro';
import { getCollection, render } from 'astro:content';
const base = import.meta.env.BASE_URL;

const performances = await getCollection('performances', ({ data }) => !data.draft);
const featured = performances.find(p => p.data.featured);

if (!featured) return Astro.redirect(`${base}archive`);

const { Content } = await render(featured);

const dateObj = new Date(featured.data.date);
const formattedDate = dateObj.toLocaleDateString('en-GB', {
  day: 'numeric', month: 'long', year: 'numeric'
});
---

<PageLayout
  title="Featured Performance"
  heading={featured.data.title}
  subheading={`${formattedDate} · ${featured.data.venue}${featured.data.location ? ', ' + featured.data.location : ''}`}
  description={featured.data.description}
>

  <!-- Video embed placeholder -->
  {featured.data.videoUrl ? (
    <div class="video-embed" style="margin-bottom: var(--space-lg);">
      <iframe
        src={featured.data.videoUrl}
        title={`Video: ${featured.data.title}`}
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen
      ></iframe>
    </div>
  ) : (
    <div class="video-placeholder">
      <p class="label">Video</p>
      <p>Video documentation will be added here when available.</p>
    </div>
  )}

  <!-- Image gallery placeholder -->
  <div class="gallery-section">
    <p class="label" style="margin-bottom: var(--space-sm);">Images</p>
    {featured.data.images && featured.data.images.length > 0 ? (
      <div class="gallery">
        {featured.data.images.map((src, i) => (
          <img src={src} alt={`${featured.data.title} — image ${i + 1}`} />
        ))}
      </div>
    ) : (
      <div class="image-placeholder">
        <p>Performance photography will be added here.</p>
      </div>
    )}
  </div>

  <!-- Main content -->
  <div class="prose featured__content">
    <Content />
  </div>

  <!-- Feedback link -->
  {featured.data.feedbackFormUrl && (
    <div class="feedback-cta">
      <hr class="rule" />
      <p class="label">Attended this performance?</p>
      <p>We'd love to hear about your experience.</p>
      <a href={featured.data.feedbackFormUrl} class="btn btn--crimson" target="_blank" rel="noopener">
        Share your feedback
      </a>
    </div>
  )}

  <!-- Archive link -->
  <div style="margin-top: var(--space-xl);">
    <a href={`${base}archive`} class="btn btn--ink">View all past performances</a>
  </div>

</PageLayout>

<style>
  .video-placeholder,
  .image-placeholder {
    background-color: var(--color-parchment);
    border: 1px dashed var(--color-kraft);
    padding: var(--space-lg);
    margin-bottom: var(--space-lg);
    text-align: center;
    color: var(--color-ink-light);
    font-style: italic;
  }

  .gallery-section {
    margin-bottom: var(--space-lg);
  }

  .featured__content {
    margin-top: var(--space-lg);
  }

  .feedback-cta {
    margin-top: var(--space-lg);
    padding: var(--space-md);
    background-color: var(--color-parchment);
  }

  .feedback-cta p {
    margin-bottom: var(--space-xs);
  }

  .feedback-cta .btn {
    margin-top: var(--space-sm);
  }
</style>
