---
import PageLayout from '../layouts/PageLayout.astro';
const base = import.meta.env.BASE_URL;

// Read all bio markdown files directly — no content collection needed
const bioFiles = import.meta.glob('../content/bios/*.md', { eager: true });

const bios = Object.entries(bioFiles)
  .map(([path, mod]: [string, any]) => ({
    id:      path.split('/').pop()!.replace('.md', ''),
    name:    mod.frontmatter.name   as string,
    role:    mod.frontmatter.role   as string | undefined,
    order:   mod.frontmatter.order  as number ?? 99,
    photo:   mod.frontmatter.photo  as string | undefined,
    Content: mod.default,
  }))
  .sort((a, b) => a.order - b.order);
---

<PageLayout
  title="Biographies"
  heading="Biographies"
  description="Biographies of Bettina Varwig and collaborators involved in Music in the Flesh."
  narrow={false}
>

  <!-- Anchor list -->
  <nav class="bio-index" aria-label="Jump to biography">
    <span class="label bio-index__label">Jump to</span>
    <ul class="bio-index__list" role="list">
      {bios.map(b => (
        <li>
          <a href={`#${b.id}`} class="bio-index__link">{b.name}</a>
        </li>
      ))}
    </ul>
  </nav>

  <!-- Bio sections -->
  {bios.map(({ id, name, role, photo, Content }) => (
    <section class="bio-section" id={id}>
      <div class="bio-header">
        <h2 class="bio-name">{name}</h2>
        {role && <p class="bio-role">{role}</p>}
      </div>

      <div class={`bio-body${photo ? '' : ' bio-body--no-photo'}`}>
        {photo && (
          <img
            src={base.replace(/\/$/, '') + photo}
            alt={name}
            class="bio-photo"
          />
        )}
        <div class="prose">
          <Content />
        </div>
      </div>
    </section>
  ))}

</PageLayout>

<style>
  /* Anchor navigation */
  .bio-index {
    display: flex;
    align-items: baseline;
    gap: var(--space-sm);
    flex-wrap: wrap;
    border-top: 1px solid var(--color-kraft);
    border-bottom: 1px solid var(--color-kraft);
    padding-block: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .bio-index__label {
    color: var(--color-ink-light);
    flex-shrink: 0;
  }

  .bio-index__list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.25em 0;
    list-style: none;
  }

  .bio-index__list li + li::before {
    content: '·';
    margin-inline: 0.6em;
    color: var(--color-kraft);
  }

  .bio-index__link {
    font-family: var(--font-display);
    font-size: var(--size-sm);
    color: var(--color-crimson);
    border-bottom: 1px solid transparent;
    transition: border-color var(--transition);
  }

  .bio-index__link:hover {
    border-color: var(--color-crimson);
    opacity: 1;
  }

  /* Individual bio section */
  .bio-section {
    border-top: 1px solid var(--color-kraft);
    padding-top: var(--space-lg);
    margin-bottom: var(--space-xl);
    scroll-margin-top: 5rem;
  }

  .bio-header {
    margin-bottom: var(--space-md);
  }

  .bio-name {
    font-size: var(--size-2xl);
    color: var(--color-ink);
    margin-bottom: 0.2em;
  }

  .bio-role {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-slate);
    font-size: var(--size-md);
  }

  .bio-body {
    display: grid;
    grid-template-columns: 220px minmax(0, 60ch);
    gap: var(--space-xl);
    align-items: start;
  }

  .bio-body--no-photo {
    grid-template-columns: minmax(0, 60ch);
  }

  .bio-photo {
    width: 100%;
    height: auto;
    filter: grayscale(20%) sepia(10%);
    border: 1px solid var(--color-kraft);
    margin-top: 0.25em;
  }

  @media (max-width: 768px) {
    .bio-body {
      grid-template-columns: 1fr;
    }

    .bio-photo {
      max-width: 200px;
    }
  }
</style>
