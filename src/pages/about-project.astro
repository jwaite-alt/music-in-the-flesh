---
import PageLayout from '../layouts/PageLayout.astro';
import { getEntry, render } from 'astro:content';
const base = import.meta.env.BASE_URL;
const projectPage = await getEntry('pages', 'about-project');
const { Content: ProjectContent } = await render(projectPage);
---

<PageLayout
  title="About the Project"
  heading="About the Project"
  subheading="Music in the Flesh — performance, research, experiment"
  description="About the Music in the Flesh project — connecting Bettina Varwig's scholarship with live performance experiments."
  narrow
>

  <div class="prose">
    <ProjectContent />
    <div style="margin-top: var(--space-lg); display: flex; gap: var(--space-sm); flex-wrap: wrap;">
      <a href={`${base}featured`} class="btn btn--crimson">Featured Performance</a>
      <a href={`${base}about`} class="btn btn--ink">About Bettina</a>
    </div>
  </div>

</PageLayout>
