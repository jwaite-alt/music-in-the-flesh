---
/**
 * EventCard — shared design system component.
 * Used on Featured Performance, Archive, and Upcoming Events pages.
 * Sibling sites (Gospel Oak Chorale, Music in Motion) can import
 * this component and override CSS variables for their own skin.
 */
interface Props {
  title: string;
  date: string;
  venue: string;
  description: string;
  href?: string;
  slug?: string;
  tag?: string;
}

const { title, date, venue, description, href, slug, tag } = Astro.props;
const link = href ?? (slug ? `/archive/${slug}` : undefined);

const dateObj = new Date(date);
const formattedDate = dateObj.toLocaleDateString('en-GB', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<article class="event-card">
  {tag && <span class="event-card__tag label">{tag}</span>}
  <p class="event-card__date label">{formattedDate}</p>
  <h3 class="event-card__title">
    {link ? <a href={link}>{title}</a> : title}
  </h3>
  <p class="event-card__venue">{venue}</p>
  <p class="event-card__desc">{description}</p>
  {link && (
    <a href={link} class="event-card__more btn btn--crimson">Read more</a>
  )}
</article>

<style>
  .event-card {
    border-top: 1px solid var(--color-kraft);
    padding-top: var(--space-md);
    padding-bottom: var(--space-md);
  }

  .event-card__tag {
    display: inline-block;
    color: var(--color-crimson);
    margin-bottom: var(--space-xs);
  }

  .event-card__date {
    color: var(--color-ink-light);
    margin-bottom: 0.25em;
  }

  .event-card__title {
    font-size: var(--size-xl);
    color: var(--color-ink);
    margin-bottom: 0.25em;
  }

  .event-card__title a {
    color: inherit;
    text-decoration: none;
    transition: color var(--transition);
  }

  .event-card__title a:hover {
    color: var(--color-crimson);
    opacity: 1;
  }

  .event-card__venue {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--color-slate);
    margin-bottom: var(--space-sm);
  }

  .event-card__desc {
    color: var(--color-ink-light);
    max-width: 60ch;
    margin-bottom: var(--space-sm);
  }

  .event-card__more {
    font-size: var(--size-xs);
    padding: 0.5em 1.5em;
  }
</style>
